# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/template_db

# ─── Authorization (auth.withfbraun.com) ─────────────────────────────────────
AUTH_URL=https://auth.withfbraun.com

# API klíč aplikace — vytvoří se v auth.withfbraun.com přes
# POST /api/integrator/apps/{app_id}/clients (zobrazí se jen jednou).
# Bez něj funguje jen refresh/logout/me; register a login vyžadují X-Api-Key.
AUTH_API_KEY=

# ─── Logging ─────────────────────────────────────────────────────────────────
LOGGING_DIR=./logs
LOGGING_FILENAME=auth.log
LOGGING_DAYS_HISTORY=5
LOGGING_MESSAGE_FORMAT=%(asctime)s %(levelname)s\t- %(module)s.%(funcName)s: %(message)s
LOGGING_LEVEL=INFO

# ─── Email (SMTP) ────────────────────────────────────────────────────────────
MAIL_USERNAME=your-smtp-username
MAIL_PASSWORD=your-smtp-password
MAIL_FROM=noreply@example.com
MAIL_SERVER=smtp.example.com
MAIL_PORT=587
MAIL_STARTTLS=true
MAIL_SSL_TLS=false
# Set to true to skip actual sending (useful for development)
MAIL_SUPPRESS_SEND=false

# ─── Application ─────────────────────────────────────────────────────────────
APP_BASE_URL=http://localhost:8000

# URL frontendu použitá v emailových odkazech (verify, reset).
# Pro více aplikací uveď tu, která obsluhuje tyto flows.
FRONTEND_URL=http://localhost:3000

# Pokud CORS řeší reverse proxy (nginx/traefik), nastav CORS_ENABLED=false.
# Zabrání duplicitním hlavičkám a není potřeba nic měnit při přidání nové app.
# Bearer tokeny fungují s Access-Control-Allow-Origin: * bez omezení.
CORS_ENABLED=true

# Ignorováno při CORS_ENABLED=false.
# Příklad pro více aplikací: ["https://app1.example.com", "https://app2.example.com"]
CORS_ORIGINS=["http://localhost:3000"]
