# Build configuration — copy to build.config.toml and fill in your values.
# build.config.toml is gitignored (contains FTP credentials).

# Deliberately public trial API key baked into the packaged frontend build's
# .env - lets people try the demo build without registering their own
# application on the auth service. Not a real secret; never use this pattern
# for an actual application's own API key (see CLAUDE.md's Deployment notes).
# Must stay top-level (read as cfg.get("client_api_key"), not nested under
# [build] or any other table).
client_api_key = "your-public-trial-api-key"

[ftp]
host     = "ftp.example.com"
port     = 21
user     = "ftp-user"
password = "secret"
passive  = true
tls      = false          # set true for FTPS (FTP over TLS)

[ftp.paths]
backend  = "/releases/backend"
frontend = "/releases/frontend"
scripts  = "/releases/auth"

[build]
output_dir  = "dist"      # relative to repo root, or absolute
# npm_command = "npm"     # override if npm is not on PATH
