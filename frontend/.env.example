# Base URL of the auth service API (no trailing slash)
VITE_API_URL=http://localhost:8000

# Base URL of this frontend app (used for OAuth callbacks, email links)
VITE_APP_URL=http://localhost:5173

# Public base URL of auth.withfbraun.com itself - needed only for the browser
# redirects (Google OAuth, hosted consent page) that can't go through the
# backend proxy. No secret involved; safe to expose to the client.
VITE_AUTH_URL=https://auth.withfbraun.com
